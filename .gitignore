# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
.venv/
venv/
env/

# SQLite database — never commit; Railway volume holds prod data.
# Catch-all also covers backend/data.db that uvicorn creates when run
# outside scripts/dev.sh, plus any future stray .db file.
backend/*.db
backend/*.db-journal
backend/*.db-wal
backend/*.db-shm

# Timestamp for scripts/dev.sh auto-sync logic (local-only)
backend/.last-prod-sync

# Env files (secrets)
.env
.env.local
.env.*.local

# Editor/OS
.DS_Store
.idea/
.vscode/
*.swp

# Node (only if you ever add any tooling)
node_modules/

# Claude
.claude/
.gstack/

# One-shot data backups (e.g. base44 corpus snapshot before regeneration)
data/*.json
